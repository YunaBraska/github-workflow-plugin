<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin require-restart="false">
    <id>com.github.yunabraska.githubworkflowplugin</id>
    <name>GitHub Workflow</name>
    <vendor url="https://github.com/YunaBraska/github-workflow-plugin">Yuna Morgenstern</vendor>
    <resource-bundle>messages.GitHubWorkflowBundle</resource-bundle>

    <!-- Default -->
    <depends>com.intellij.modules.platform</depends>
    <!-- Access to private workflows & actions -->
    <depends>org.jetbrains.plugins.github</depends>
    <!-- Parsing YAML Elements -->
    <depends>org.jetbrains.plugins.yaml</depends>
    <!-- Parsing JSON Elements (SCHEMA) -->
    <depends>com.intellij.modules.json</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Auto Completion -->
        <completion.contributor language="yaml"
                                implementationClass="com.github.yunabraska.githubworkflow.entry.WorkflowCompletion"/>
        <completion.contributor language="Shell Script"
                                implementationClass="com.github.yunabraska.githubworkflow.entry.WorkflowCompletion"/>
        <typedHandler implementation="com.github.yunabraska.githubworkflow.entry.WorkflowCompletion$TypedAutoPopup"
                      order="first, before completionAutoPopup"/>
        <enterHandlerDelegate implementation="com.github.yunabraska.githubworkflow.entry.WorkflowCompletion$EnterAutoPopup"
                              order="last"/>
        <completion.confidence implementationClass="com.github.yunabraska.githubworkflow.entry.WorkflowCompletion$Confidence"
                               order="first"/>
        <!-- Syntax Highlighting -->
        <annotator language="yaml"
                   implementationClass="com.github.yunabraska.githubworkflow.entry.WorkflowAnnotator"/>

        <!-- Jump to position-->
        <psi.referenceContributor language="yaml" implementation="com.github.yunabraska.githubworkflow.syntax.WorkflowReferences$Contributor"/>
        <lang.documentationProvider id="GithubWorkflowDocumentationProvider"
                                    language="yaml"
                                    implementationClass="com.github.yunabraska.githubworkflow.entry.WorkflowDocumentationProvider"
                                    order="before YamlJsonSchemaDocumentationProvider"/>
        <multiHostInjector implementation="com.github.yunabraska.githubworkflow.syntax.WorkflowSyntax$RunLanguageInjector"/>
        <configurationType implementation="com.github.yunabraska.githubworkflow.run.WorkflowRunConfiguration$Type"/>
        <runConfigurationProducer implementation="com.github.yunabraska.githubworkflow.run.WorkflowRunConfiguration$Producer"/>
        <runLineMarkerContributor language="yaml"
                                  implementationClass="com.github.yunabraska.githubworkflow.run.WorkflowRun$LineMarkerContributor"/>

        <!-- Project startup -->
        <postStartupActivity implementation="com.github.yunabraska.githubworkflow.state.GitHubActionCache$Startup"/>

        <!-- Cache [Workflows, Actions, Schemas] -->
        <applicationService serviceImplementation="com.github.yunabraska.githubworkflow.state.GitHubActionCache"
                            configurationSchemaKey="GitHubActionCache"/>
        <applicationService serviceImplementation="com.github.yunabraska.githubworkflow.git.RemoteActionProviders$Settings"/>
        <applicationService serviceImplementation="com.github.yunabraska.githubworkflow.i18n.GitHubWorkflowBundle$Settings"/>
        <applicationConfigurable instance="com.github.yunabraska.githubworkflow.settings.GitHubWorkflowSettingsConfigurable"
                                 id="github.workflow.settings"
                                 parentId="tools"
                                 key="settings.displayName"
                                 bundle="messages.GitHubWorkflowBundle"/>
        <projectService serviceImplementation="com.github.yunabraska.githubworkflow.run.WorkflowRun$Tracker"/>

        <!-- Schema Icon provider -->
        <iconProvider implementation="com.github.yunabraska.githubworkflow.syntax.WorkflowSyntax$FileIcon"/>

        <!-- Crash Reporter -->
        <errorHandler implementation="com.github.yunabraska.githubworkflow.i18n.GitHubWorkflowBundle$ErrorReporter"/>

        <notificationGroup id="GitHub Workflow"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
    </extensions>

    <extensions defaultExtensionNs="JavaScript.JsonSchema">
        <!-- Schema Registry -->
        <ProviderFactory implementation="com.github.yunabraska.githubworkflow.syntax.WorkflowSyntax$Schema"/>
    </extensions>

    <actions resource-bundle="messages.GitHubWorkflowBundle">
        <group id="GitHubWorkflow.Tools" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="GitHubWorkflow.RefreshActionCache"
                    class="com.github.yunabraska.githubworkflow.state.GitHubActionCache$RefreshAction"/>
            <action id="GitHubWorkflow.RestoreActionWarnings"
                    class="com.github.yunabraska.githubworkflow.state.GitHubActionCache$RestoreWarningsAction"/>
            <action id="GitHubWorkflow.ClearActionCache"
                    class="com.github.yunabraska.githubworkflow.state.GitHubActionCache$ClearAction"/>
        </group>
    </actions>
</idea-plugin>
